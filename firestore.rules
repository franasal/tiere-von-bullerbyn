rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn()
        && request.auth.token.firebase.sign_in_provider != 'anonymous';
    }

    function isValidNotePayload(data) {
      return data.animalKey is string
        && data.animalName is string
        && data.animalKey.size() > 0
        && data.animalName.size() > 0
        && data.text is string
        && data.text.size() >= 10
        && data.text.size() <= 500
        && data.author is string
        && data.author.size() <= 40
        && data.status == 'approved'
        && data.deviceUid is string
        && data.deviceUid.size() > 0
        && data.createdDay is string
        && data.createdDay.size() == 10
        && data.createdAt is timestamp;
    }

    function isValidNoteCreate(animalKey) {
      return isValidNotePayload(request.resource.data)
        && request.resource.data.animalKey == animalKey
        && request.resource.data.deviceUid == request.auth.uid;
    }

    match /notes/{animalKey}/entries/{noteId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn() && isValidNoteCreate(animalKey);

      allow update: if isAdmin()
        && isValidNotePayload(request.resource.data);

      allow delete: if isAdmin();
    }
  }
}
